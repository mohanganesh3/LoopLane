{
  "name": "carpool-platform",
  "version": "1.0.0",
  "description": "Advanced Carpooling Platform with Safety Features, Real-time Tracking, and Carbon Calculator",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "build": "cd client && npm install --legacy-peer-deps --include=dev && npm run build",
    "verify:system": "node scripts/verify_system.js",
    "verify:deployment": "BASE_URL=https://looplane.onrender.com node scripts/verify_system.js",
    "report:db": "node scripts/report-db-optimizations.js",
    "bench:redis": "node scripts/benchmark-redis-cache.js",
    "seed:admin": "node seed.js admin",
    "seed:sample": "node seed.js sample",
    "solr:reindex-users": "node scripts/solr/reindex-users.js",
    "solr:reindex-users:clean": "node scripts/solr/reindex-users.js --delete-all"
  },
  "keywords": [
    "carpool",
    "rideshare",
    "eco-friendly",
    "safety",
    "real-time"
  ],
  "author": "Mohan Ganesh",
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^1.43.0",
    "@turf/turf": "^7.3.4",
    "aws-sdk": "^2.1693.0",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "compression": "^1.8.1",
    "connect-flash": "^0.1.1",
    "connect-mongo": "^5.1.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-async-handler": "^1.2.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.1",
    "h3-js": "^4.4.0",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.3",
    "moment": "^2.30.1",
    "mongoose": "^8.14.1",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.10.1",
    "rate-limit-redis": "^4.2.0",
    "rotating-file-stream": "^3.2.9",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^4.23.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "marked": "^16.4.0",
    "nodemon": "^3.1.14",
    "puppeteer": "^24.37.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
